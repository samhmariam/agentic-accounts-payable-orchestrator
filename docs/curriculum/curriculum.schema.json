{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisap.local/curriculum.schema.json",
  "title": "AegisAP Curriculum Manifest",
  "type": "object",
  "required": [
    "daily_pass_bar",
    "elite_pass_bar",
    "bootstrap_day",
    "customer_profile",
    "days"
  ],
  "properties": {
    "daily_pass_bar": {
      "type": "integer"
    },
    "elite_pass_bar": {
      "type": "integer"
    },
    "graduation_tiers": {
      "type": "object"
    },
    "bootstrap_day": {
      "type": "object",
      "required": [
        "id",
        "title",
        "notebook_file",
        "primary_doc_file",
        "artifact_files",
        "portal_to_script_mapping",
        "customer_context",
        "automation_drills",
        "persistent_constraints",
        "mastery_gates",
        "chaos_gate",
        "oral_defense_objectives",
        "phase",
        "incident_asset_ref",
        "injection_command",
        "revert_state",
        "verification_commands",
        "review_contract"
      ],
      "additionalProperties": true
    },
    "customer_profile": {
      "type": "object",
      "required": [
        "name",
        "operating_context",
        "non_negotiables"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "operating_context": {
          "type": "string",
          "minLength": 1
        },
        "non_negotiables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "days": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "scaffold_level",
          "notebook_file",
          "primary_doc_file",
          "legacy_doc_files",
          "rubric_weights",
          "artifact_files",
          "portal_to_script_mapping",
          "customer_context",
          "automation_drills",
          "persistent_constraints",
          "mastery_gates",
          "chaos_gate",
          "oral_defense_objectives",
          "zero_tolerance",
          "capstone_flags",
          "phase",
          "incident_asset_ref",
          "injection_command",
          "revert_state",
          "verification_commands",
          "review_contract"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{2}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "scaffold_level": {
            "type": "string",
            "enum": [
              "guided",
              "reduced",
              "starter_only"
            ]
          },
          "notebook_file": {
            "type": "string",
            "minLength": 1
          },
          "primary_doc_file": {
            "type": "string",
            "minLength": 1
          },
          "legacy_doc_files": {
            "type": "array"
          },
          "rubric_weights": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "integer"
            }
          },
          "artifact_files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "portal_to_script_mapping": {
            "type": "object",
            "required": [
              "portal_surface",
              "bridge_file",
              "repair_domains"
            ],
            "properties": {
              "portal_surface": {
                "type": "string",
                "minLength": 1
              },
              "bridge_file": {
                "type": "string",
                "minLength": 1
              },
              "repair_domains": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/repairDomain"
                }
              }
            },
            "additionalProperties": true
          },
          "customer_context": {
            "type": "string",
            "minLength": 1
          },
          "cost_of_failure": {
            "type": "string",
            "minLength": 1
          },
          "stakeholder_inject": {
            "$ref": "#/$defs/stakeholderInject"
          },
          "automation_drills": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/automationDrill"
            }
          },
          "native_operator_evidence": {
            "$ref": "#/$defs/nativeOperatorEvidence"
          },
          "kql_evidence": {
            "$ref": "#/$defs/kqlEvidenceContract"
          },
          "diagnostic_independence": {
            "$ref": "#/$defs/diagnosticIndependenceContract"
          },
          "rollback_rehearsal": {
            "$ref": "#/$defs/rollbackRehearsal"
          },
          "persistent_constraints": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/constraint"
            }
          },
          "mastery_gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/masteryGate"
            }
          },
          "chaos_gate": {
            "$ref": "#/$defs/chaosGate"
          },
          "oral_defense_objectives": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "zero_tolerance": {
            "type": "array"
          },
          "capstone_flags": {
            "type": "object"
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "incident_asset_ref": {
            "type": "string",
            "minLength": 1
          },
          "injection_command": {
            "type": "string",
            "minLength": 1
          },
          "revert_state": {
            "type": "string",
            "minLength": 1
          },
          "verification_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_contract": {
            "$ref": "#/$defs/reviewContract"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "repairDomain": {
      "type": "object",
      "required": [
        "name",
        "surface_type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "surface_type": {
          "type": "string",
          "enum": [
            "application",
            "infrastructure",
            "ci_cd",
            "policy",
            "eval"
          ]
        }
      },
      "additionalProperties": false
    },
    "constraint": {
      "type": "object",
      "required": [
        "id",
        "type",
        "description",
        "introduced_on",
        "persists"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "business",
            "application",
            "identity",
            "infrastructure",
            "process"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "introduced_on": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "persists": {
          "const": true
        },
        "superseded_by": {
          "type": "string",
          "minLength": 1
        },
        "supersession_reason": {
          "type": "string",
          "minLength": 1
        },
        "approver_role": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "masteryGate": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "command",
        "success_marker",
        "covers_constraints",
        "evidence_source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "success_marker": {
          "type": "string",
          "minLength": 1
        },
        "covers_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_source": {
          "type": "string",
          "enum": [
            "unit_test",
            "static_analysis",
            "artifact",
            "cloud_probe",
            "workflow"
          ]
        }
      },
      "additionalProperties": true
    },
    "nativeOperatorEvidence": {
      "type": "object",
      "required": [
        "artifact_path",
        "mode",
        "review_stage",
        "live_demo_required"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ]
        },
        "review_stage": {
          "type": "string",
          "minLength": 1
        },
        "live_demo_required": {
          "type": "boolean"
        },
        "minimum_commands": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_queries": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_pre_patch_commands": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_pre_patch_queries": {
          "type": "integer",
          "minimum": 0
        },
        "must_use_json_output": {
          "type": "boolean"
        },
        "required_signal_families": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nativeSignalFamily"
          }
        }
      },
      "additionalProperties": true
    },
    "kqlEvidenceContract": {
      "type": "object",
      "required": [
        "artifact_path",
        "minimum_queries",
        "review_stage"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "minimum_queries": {
          "type": "integer",
          "minimum": 1
        },
        "minimum_pre_patch_queries": {
          "type": "integer",
          "minimum": 0
        },
        "review_stage": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "diagnosticIndependenceContract": {
      "type": "object",
      "required": [
        "mode",
        "timeline_artifact_path",
        "review_stage"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ]
        },
        "timeline_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "review_stage": {
          "type": "string",
          "minLength": 1
        },
        "hint_state_path": {
          "type": "string",
          "minLength": 1
        },
        "required_markers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "chaosGate": {
      "type": "object",
      "required": [
        "failure_signal",
        "starting_signal",
        "expected_recovery_artifact",
        "time_box_minutes",
        "facilitator_intervention_rule"
      ],
      "properties": {
        "failure_signal": {
          "type": "string",
          "minLength": 1
        },
        "starting_signal": {
          "type": "string",
          "minLength": 1
        },
        "expected_recovery_artifact": {
          "type": "string",
          "minLength": 1
        },
        "time_box_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "facilitator_intervention_rule": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "automationDrill": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "name",
        "description",
        "expected_signal"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "incident",
            "artifact"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "repair_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "drift_layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "application",
              "identity",
              "networking",
              "iac",
              "ci_cd"
            ]
          }
        },
        "expected_signal": {
          "type": "string",
          "minLength": 1
        },
        "shadow_origin_day": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "secondary_failure_signal": {
          "type": "string",
          "minLength": 1
        },
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "mutation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "stakeholderInject": {
      "type": "object",
      "required": [
        "requester_role",
        "channel",
        "unsafe_request",
        "required_artifacts",
        "delivery_mode",
        "script_path",
        "role_cards",
        "required_questions",
        "capture_artifact",
        "observer_scorecard"
      ],
      "properties": {
        "requester_role": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "unsafe_request": {
          "type": "string",
          "minLength": 1
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "delivery_mode": {
          "type": "string",
          "enum": [
            "static_markdown",
            "facilitated_script",
            "triad_roleplay"
          ]
        },
        "script_path": {
          "type": "string",
          "minLength": 1
        },
        "role_cards": {
          "type": "object",
          "required": [
            "interviewer",
            "stakeholder",
            "observer_scribe"
          ],
          "properties": {
            "interviewer": {
              "type": "string",
              "minLength": 1
            },
            "stakeholder": {
              "type": "string",
              "minLength": 1
            },
            "observer_scribe": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "required_questions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "capture_artifact": {
          "type": "string",
          "minLength": 1
        },
        "observer_scorecard": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "nativeSignalFamily": {
      "type": "object",
      "required": [
        "name",
        "command_patterns",
        "output_patterns",
        "minimum_matches"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "command_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "minimum_matches": {
          "type": "integer",
          "minimum": 1
        },
        "must_use_json_output": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "rollbackRehearsal": {
      "type": "object",
      "required": [
        "artifact_path",
        "traffic_shift_required",
        "command_patterns",
        "verification_patterns",
        "health_checks",
        "readiness_retry_policy"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "traffic_shift_required": {
          "type": "boolean"
        },
        "command_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "verification_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "health_checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readiness_retry_policy": {
          "type": "object",
          "required": [
            "initial_delay_seconds",
            "max_attempts",
            "backoff_multiplier"
          ],
          "properties": {
            "initial_delay_seconds": {
              "type": "integer",
              "minimum": 0
            },
            "max_attempts": {
              "type": "integer",
              "minimum": 1
            },
            "backoff_multiplier": {
              "type": "number",
              "minimum": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "reviewContract": {
      "type": "object",
      "required": [
        "evaluator_profile",
        "human_required"
      ],
      "properties": {
        "evaluator_profile": {
          "type": "string",
          "minLength": 1
        },
        "human_required": {
          "type": "boolean"
        },
        "review_mode": {
          "type": "string",
          "enum": [
            "standard",
            "cab_board"
          ]
        },
        "required_review_roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requires_kql_replay": {
          "type": "boolean"
        },
        "requires_revert_proof": {
          "type": "boolean"
        },
        "peer_checklist_file": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
