{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aegisap.local/curriculum.schema.json",
  "title": "AegisAP Curriculum Manifest",
  "type": "object",
  "required": [
    "daily_pass_bar",
    "elite_pass_bar",
    "customer_profile",
    "days"
  ],
  "properties": {
    "daily_pass_bar": {
      "type": "integer"
    },
    "elite_pass_bar": {
      "type": "integer"
    },
    "graduation_tiers": {
      "type": "object"
    },
    "customer_profile": {
      "type": "object",
      "required": [
        "name",
        "operating_context",
        "non_negotiables"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "operating_context": {
          "type": "string",
          "minLength": 1
        },
        "non_negotiables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "days": {
      "type": "array",
      "minItems": 14,
      "maxItems": 14,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "scaffold_level",
          "notebook_file",
          "primary_doc_file",
          "legacy_doc_files",
          "rubric_weights",
          "artifact_files",
          "portal_to_script_mapping",
          "customer_context",
          "automation_drills",
          "persistent_constraints",
          "mastery_gates",
          "chaos_gate",
          "oral_defense_prompts",
          "zero_tolerance",
          "capstone_flags",
          "phase",
          "scenario_dir",
          "injection_command",
          "revert_state",
          "verification_commands",
          "review_contract"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]{2}$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "scaffold_level": {
            "type": "string",
            "enum": [
              "guided",
              "reduced",
              "starter_only"
            ]
          },
          "notebook_file": {
            "type": "string",
            "minLength": 1
          },
          "primary_doc_file": {
            "type": "string",
            "minLength": 1
          },
          "legacy_doc_files": {
            "type": "array"
          },
          "rubric_weights": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "type": "integer"
            }
          },
          "artifact_files": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "portal_to_script_mapping": {
            "type": "object",
            "required": [
              "portal_surface",
              "bridge_file",
              "production_targets"
            ],
            "properties": {
              "portal_surface": {
                "type": "string",
                "minLength": 1
              },
              "bridge_file": {
                "type": "string",
                "minLength": 1
              },
              "production_targets": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/productionTarget"
                }
              }
            },
            "additionalProperties": true
          },
          "customer_context": {
            "type": "string",
            "minLength": 1
          },
          "cost_of_failure": {
            "type": "string",
            "minLength": 1
          },
          "stakeholder_inject": {
            "$ref": "#/$defs/stakeholderInject"
          },
          "automation_drills": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/automationDrill"
            }
          },
          "native_operator_evidence": {
            "$ref": "#/$defs/nativeOperatorEvidence"
          },
          "kql_evidence": {
            "$ref": "#/$defs/kqlEvidenceContract"
          },
          "persistent_constraints": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/constraint"
            }
          },
          "mastery_gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/masteryGate"
            }
          },
          "chaos_gate": {
            "$ref": "#/$defs/chaosGate"
          },
          "oral_defense_prompts": {
            "type": "array",
            "minItems": 3,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "zero_tolerance": {
            "type": "array"
          },
          "capstone_flags": {
            "type": "object"
          },
          "phase": {
            "type": "string",
            "minLength": 1
          },
          "scenario_dir": {
            "type": "string",
            "minLength": 1
          },
          "injection_command": {
            "type": "string",
            "minLength": 1
          },
          "revert_state": {
            "type": "string",
            "minLength": 1
          },
          "verification_commands": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_contract": {
            "$ref": "#/$defs/reviewContract"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "productionTarget": {
      "type": "object",
      "required": [
        "path",
        "surface_type"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "surface_type": {
          "type": "string",
          "enum": [
            "application",
            "infrastructure",
            "ci_cd",
            "policy",
            "eval"
          ]
        }
      },
      "additionalProperties": false
    },
    "constraint": {
      "type": "object",
      "required": [
        "id",
        "type",
        "description",
        "introduced_on",
        "persists"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "business",
            "application",
            "identity",
            "infrastructure",
            "process"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "introduced_on": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "persists": {
          "const": true
        },
        "superseded_by": {
          "type": "string",
          "minLength": 1
        },
        "supersession_reason": {
          "type": "string",
          "minLength": 1
        },
        "approver_role": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "masteryGate": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "command",
        "success_marker",
        "covers_constraints",
        "evidence_source"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ]
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "success_marker": {
          "type": "string",
          "minLength": 1
        },
        "covers_constraints": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_source": {
          "type": "string",
          "enum": [
            "unit_test",
            "static_analysis",
            "artifact",
            "cloud_probe",
            "workflow"
          ]
        }
      },
      "additionalProperties": true
    },
    "nativeOperatorEvidence": {
      "type": "object",
      "required": [
        "artifact_path",
        "mode",
        "review_stage",
        "live_demo_required"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "advisory",
            "blocking"
          ]
        },
        "review_stage": {
          "type": "string",
          "minLength": 1
        },
        "live_demo_required": {
          "type": "boolean"
        },
        "minimum_commands": {
          "type": "integer",
          "minimum": 0
        },
        "minimum_queries": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "kqlEvidenceContract": {
      "type": "object",
      "required": [
        "artifact_path",
        "minimum_queries",
        "review_stage"
      ],
      "properties": {
        "artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "minimum_queries": {
          "type": "integer",
          "minimum": 1
        },
        "review_stage": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "chaosGate": {
      "type": "object",
      "required": [
        "failure_signal",
        "diagnostic_surface",
        "expected_recovery_artifact",
        "time_box_minutes",
        "facilitator_intervention_rule"
      ],
      "properties": {
        "failure_signal": {
          "type": "string",
          "minLength": 1
        },
        "diagnostic_surface": {
          "type": "string",
          "minLength": 1
        },
        "expected_recovery_artifact": {
          "type": "string",
          "minLength": 1
        },
        "time_box_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "facilitator_intervention_rule": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "automationDrill": {
      "type": "object",
      "required": [
        "id",
        "mode",
        "name",
        "description",
        "expected_signal"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "default": {
          "type": "boolean"
        },
        "mode": {
          "type": "string",
          "enum": [
            "incident",
            "artifact"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "repair_targets": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "drift_layers": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "application",
              "identity",
              "networking",
              "iac",
              "ci_cd"
            ]
          }
        },
        "expected_signal": {
          "type": "string",
          "minLength": 1
        },
        "shadow_origin_day": {
          "type": "string",
          "pattern": "^[0-9]{2}$"
        },
        "secondary_failure_signal": {
          "type": "string",
          "minLength": 1
        },
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "mutation": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    },
    "stakeholderInject": {
      "type": "object",
      "required": [
        "requester_role",
        "channel",
        "unsafe_request",
        "required_artifacts"
      ],
      "properties": {
        "requester_role": {
          "type": "string",
          "minLength": 1
        },
        "channel": {
          "type": "string",
          "minLength": 1
        },
        "unsafe_request": {
          "type": "string",
          "minLength": 1
        },
        "required_artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": true
    },
    "reviewContract": {
      "type": "object",
      "required": [
        "evaluator_profile",
        "human_required"
      ],
      "properties": {
        "evaluator_profile": {
          "type": "string",
          "minLength": 1
        },
        "human_required": {
          "type": "boolean"
        },
        "review_mode": {
          "type": "string",
          "enum": [
            "standard",
            "cab_board"
          ]
        },
        "required_review_roles": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "requires_kql_replay": {
          "type": "boolean"
        },
        "requires_revert_proof": {
          "type": "boolean"
        },
        "peer_checklist_file": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
