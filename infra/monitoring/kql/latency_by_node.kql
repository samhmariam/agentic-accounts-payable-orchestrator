AppTraces
| extend workflow_run_id = tostring(Properties["aegis.workflow_run_id"])
| extend node_name = tostring(Properties["aegis.node_name"])
| extend duration_ms = todouble(Properties["duration_ms"])
| where isnotempty(node_name)
| summarize p50=percentile(duration_ms, 50), p95=percentile(duration_ms, 95), count() by node_name
| order by p95 desc
