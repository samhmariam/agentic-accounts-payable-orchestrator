using './notebook.bicep'

// ─────────────────────────────────────────────────────────────────────────────
// AegisAP Notebook Provisioning — parameter reference
//
// Do NOT edit this file for normal use. Control provisioning through azd:
//
//   azd env new <day-cluster>          # e.g. day-3, day-8, day-14
//   azd env set NOTEBOOK_PROFILE    core|standard|full|advanced
//   azd env set AZURE_LOCATION      <region>        # e.g. eastus
//
//   # Days 5+ only — get your object ID with:
//   #   az ad signed-in-user show --query id -o tsv
//   azd env set POSTGRES_ADMIN_OBJECT_ID  <your-entra-oid>
//   azd env set POSTGRES_ADMIN_NAME       <your-upn>
//
//   azd provision        # create / update resources
//   azd down             # tear down the resource group
//
// Resource names are derived from AZURE_ENV_NAME — no name parameters required.
// ─────────────────────────────────────────────────────────────────────────────

// Set automatically by azd — do not set manually
param envName = '<set-by-azd>'             // AZURE_ENV_NAME
param location = '<set-by-azd>'            // AZURE_LOCATION

// ── NOTEBOOK_PROFILE ──────────────────────────────────────────────────────────
// core     → Days 3-4:   Storage, Azure OpenAI, Azure AI Search
// standard → Days 5-7:   + PostgreSQL, Content Safety, Cosmos DB, ADF
// full     → Days 8-10:  + ACR, Key Vault, ACA environment, Log Analytics,
//                           Application Insights, Azure Machine Learning
// advanced → Days 11-14: + VNet, Private Endpoints, Private DNS, Service Bus
param notebookProfile = 'core'             // NOTEBOOK_PROFILE

// ── PostgreSQL admin (required when profile is 'standard' or above) ───────────
// Run: az ad signed-in-user show --query id -o tsv
param postgresAdminObjectId = ''           // POSTGRES_ADMIN_OBJECT_ID
param postgresAdminName = ''               // POSTGRES_ADMIN_NAME

// ── Azure OpenAI deployment (all profiles) ────────────────────────────────────
// Leave openAiChatModelName empty to skip automatic deployment creation.
// The deployment (openAiChatDeploymentName) is created only when
// openAiChatModelName is non-empty.
param openAiChatDeploymentName = 'chat'    // AZURE_OPENAI_CHAT_DEPLOYMENT
param openAiChatModelName = ''             // AZURE_OPENAI_MODEL_NAME      e.g. gpt-4o
param openAiChatModelVersion = ''          // AZURE_OPENAI_MODEL_VERSION    e.g. 2024-11-20

// ── API version override (optional) ──────────────────────────────────────────
// Change here if you need a different OpenAI REST API version.
param openAiApiVersion = '2024-08-01-preview'
