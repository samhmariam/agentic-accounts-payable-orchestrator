# Copy this file to .env only if you need a local file-based env source.
# The recommended Day 0 flow is:
# 1. run scripts/provision-core.ps1 or scripts/provision-full.ps1
# 2. dot-source scripts/setup-env.ps1 -Track <core|full>
# 3. verify with scripts/verify_env.py
#
# Never commit .env or populated .bicepparam files.

# Security mode
AEGISAP_ENVIRONMENT=local

# Core Day 0
AZURE_SUBSCRIPTION_ID=<subscription-id>
AZURE_RESOURCE_GROUP=<resource-group-name>
AZURE_LOCATION=<azure-region>
AZURE_OPENAI_ENDPOINT=https://<azure-openai-name>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_CHAT_DEPLOYMENT=<chat-deployment-name>
AZURE_SEARCH_ENDPOINT=https://<search-service-name>.search.windows.net
AZURE_SEARCH_INDEX=documents
AZURE_SEARCH_DAY3_INDEX=day3-evidence
AZURE_STORAGE_ACCOUNT_URL=https://<storage-account-name>.blob.core.windows.net
AZURE_STORAGE_CONTAINER=documents

# Full platform track only
AZURE_POSTGRES_HOST=<postgres-server-name>.postgres.database.azure.com
AZURE_POSTGRES_PORT=5432
AZURE_POSTGRES_DB=aegisap
AZURE_POSTGRES_USER=<entra-principal-name>
AZURE_KEY_VAULT_URI=https://<key-vault-name>.vault.azure.net/
APPLICATIONINSIGHTS_CONNECTION_STRING=<application-insights-connection-string>

# Optional training runtime helpers
# Local-only PostgreSQL escape hatch. Do not use in staging or production-like environments.
AEGISAP_POSTGRES_DSN=
# Resume token secret name used for Key Vault lookup on the full track.
AEGISAP_RESUME_TOKEN_SECRET_NAME=aegisap-resume-token-secret
# Local-only shortcut for the Day 5 and Day 7 labs when Key Vault is not in use.
AEGISAP_RESUME_TOKEN_SECRET=dev-only-resume-secret

# Optional LangSmith
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# Optional service principal auth for DefaultAzureCredential
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
